# === ZALO ===
ZALO_IMEI=
ZALO_COOKIE=
ZALO_USER_AGENT=

# === GOOGLE DRIVE ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback
GOOGLE_REFRESH_TOKEN=
DRIVE_FOLDER_ID=

# === POSTGRESQL + pgvector ===
PG_HOST=localhost
PG_PORT=5433
PG_DATABASE=giftzone_agent
PG_USER=postgres
PG_PASSWORD=postgres

# === ANTHROPIC (Claude AI) ===
# Lấy tại: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# === VOYAGE AI (Embedding — Free 200M tokens/tháng) ===
# Lấy tại: https://dash.voyageai.com → API Keys
VOYAGE_API_KEY=

# === AGENT CONFIG ===
# Thời gian gửi daily summary (cron format, mặc định 18:00 các ngày làm việc)
SUMMARY_CRON=0 18 * * 1-5
# Tên Agent hiển thị trong tin nhắn
AGENT_NAME=GiftZone AI
