# === ZALO ===
# Lấy từ https://chat.zalo.me → ZaloDataExtractor extension
# Hoặc DevTools: localStorage.getItem("z_uuid") | navigator.userAgent | Application > Cookies
ZALO_IMEI=your_imei_here
ZALO_COOKIE=your_cookie_string_here
ZALO_USER_AGENT=your_browser_user_agent_here
# Group ID để test gửi tin (lấy từ URL hoặc log groupIds sau khi chạy)
ZALO_TEST_GROUP_ID=

# === GOOGLE DRIVE ===
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback
GOOGLE_REFRESH_TOKEN=your_refresh_token
# ID của folder Drive cần test index (lấy từ URL folder)
DRIVE_FOLDER_ID=your_folder_id

# === POSTGRESQL + pgvector ===
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=giftzone_spike
PG_USER=postgres
PG_PASSWORD=postgres

